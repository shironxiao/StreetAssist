<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvReportId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#REP-12345"
                android:textColor="#001F54"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                app:tint="#A3AED0" />
        </RelativeLayout>

        <!-- Status & Time Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDetailStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pending"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="PENDING"
                android:textColor="@color/status_pending_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvDetailTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oct 24, 2023 • 10:30 AM"
                android:textColor="#A3AED0"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Main Details -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INCIDENT DESCRIPTION"
            android:textColor="#A3AED0"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:lineSpacingExtra="4dp"
            android:text="Vehicular accident near the main intersection. Both drivers appear safe but traffic is building up."
            android:textColor="#1B2559"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOCATION"
            android:textColor="#A3AED0"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="123 Mabini St, Manila, Metro Manila"
            android:textColor="#1B2559"
            android:textSize="14sp" />

        <!-- UPDATE STATUS SECTION (New) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="20dp"
            android:background="#F4F7FE" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UPDATE STATUS"
            android:textColor="#001F54"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnSetInProgress"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="In Progress"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:backgroundTint="@color/status_inprogress_bg"
                android:textColor="@color/status_inprogress_text"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

            <Button
                android:id="@+id/btnSetResolved"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:text="Resolved"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:backgroundTint="@color/status_resolved_bg"
                android:textColor="@color/status_resolved_text"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
        </LinearLayout>

        <!-- Reporter Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F4F7FE"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_profile_placeholder"
                app:tint="#001F54" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvReporterName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Doe"
                    android:textColor="#1B2559"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reporter"
                    android:textColor="#A3AED0"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnViewLocation"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#001F54"
            android:text="Open on Map"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="16dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
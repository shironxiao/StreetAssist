<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_top_corners"
    android:paddingBottom="32dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="#DDDDDD" />

    <!-- Header: Report ID + Status -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report Details"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <!-- EXACT ID: dialogReportId -->
            <TextView
                android:id="@+id/dialogReportId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RPT-—"
                android:textColor="#4169E1"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- EXACT ID: dialogStatus -->
        <TextView
            android:id="@+id/dialogStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="Pending"
            android:textSize="12sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginHorizontal="20dp" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── INDIVIDUAL INFORMATION ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INDIVIDUAL INFORMATION"
                android:textColor="#4169E1"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- Age + Sex side by side -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="#F4F6FF"
                    android:padding="12dp"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Approx. Age"
                        android:textColor="#888888"
                        android:textSize="10sp" />

                    <!-- EXACT ID: dialogAge -->
                    <TextView
                        android:id="@+id/dialogAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#222222"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="#F4F6FF"
                    android:padding="12dp"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sex"
                        android:textColor="#888888"
                        android:textSize="10sp" />

                    <!-- EXACT ID: dialogSex -->
                    <TextView
                        android:id="@+id/dialogSex"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#222222"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Description label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#888888"
                android:textSize="10sp"
                android:layout_marginBottom="4dp" />

            <!-- EXACT ID: dialogDescription -->
            <TextView
                android:id="@+id/dialogDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F4F6FF"
                android:padding="12dp"
                android:text="—"
                android:textColor="#333333"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp" />

            <!-- ── LAST SEEN LOCATION ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LAST SEEN LOCATION"
                android:textColor="#4169E1"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F4F6FF"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="#E53935"
                    android:layout_marginEnd="8dp" />

                <!-- EXACT ID: dialogLocation -->
                <TextView
                    android:id="@+id/dialogLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>

            <!-- Lat + Lng side by side -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="#F4F6FF"
                    android:padding="10dp"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Latitude"
                        android:textColor="#888888"
                        android:textSize="10sp" />

                    <!-- EXACT ID: dialogLatitude -->
                    <TextView
                        android:id="@+id/dialogLatitude"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#222222"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="#F4F6FF"
                    android:padding="10dp"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Longitude"
                        android:textColor="#888888"
                        android:textSize="10sp" />

                    <!-- EXACT ID: dialogLongitude -->
                    <TextView
                        android:id="@+id/dialogLongitude"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#222222"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── ASSISTANCE NEEDED ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASSISTANCE NEEDED"
                android:textColor="#4169E1"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- EXACT ID: dialogAssistance -->
            <TextView
                android:id="@+id/dialogAssistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F4F6FF"
                android:padding="12dp"
                android:text="—"
                android:textColor="#333333"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp" />

            <!-- ── REPORTER INFORMATION ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPORTER INFORMATION"
                android:textColor="#4169E1"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="#F4F6FF"
                    android:padding="12dp"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact"
                        android:textColor="#888888"
                        android:textSize="10sp" />

                    <!-- EXACT ID: dialogContact -->
                    <TextView
                        android:id="@+id/dialogContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not provided"
                        android:textColor="#222222"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="#F4F6FF"
                    android:padding="12dp"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Submitted"
                        android:textColor="#888888"
                        android:textSize="10sp" />

                    <!-- EXACT ID: dialogTimestamp -->
                    <TextView
                        android:id="@+id/dialogTimestamp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#222222"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date &amp; Time Seen"
                        android:textStyle="bold"
                        android:textColor="#333333" />

                    <TextView
                        android:id="@+id/dialogSeenAt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#555555" />
                </LinearLayout>
            </LinearLayout>

            <!-- Close Button -->
            <!-- EXACT ID: dialogBtnClose -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogBtnClose"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Close"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:backgroundTint="#4169E1"
                app:cornerRadius="14dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
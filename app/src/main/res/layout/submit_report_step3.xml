<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".ui.resident.Reports.submit_report_step3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER SECTION -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#4169E1"
            android:padding="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_bg_light_blue"
                android:backgroundTint="#5A7FE6"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@android:color/white" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/btnBack"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Submit a Report"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Report submitted successfully"
                    android:textColor="#D1D9FF"
                    android:textSize="14sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- CONTENT SECTION -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="-20dp"
            android:background="@drawable/rounded_top_corners"
            android:fillViewport="true"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <!-- STEP INDICATOR (All Completed) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/circle_bg_light_blue"
                        android:backgroundTint="#4CAF50"
                        android:padding="6dp"
                        android:src="@android:drawable/checkbox_on_background"
                        app:tint="@android:color/white" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="#4CAF50"
                        android:layout_marginHorizontal="8dp" />

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/circle_bg_light_blue"
                        android:backgroundTint="#4CAF50"
                        android:padding="6dp"
                        android:src="@android:drawable/checkbox_on_background"
                        app:tint="@android:color/white" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="#4CAF50"
                        android:layout_marginHorizontal="8dp" />

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/circle_bg_light_blue"
                        android:backgroundTint="#4CAF50"
                        android:padding="6dp"
                        android:src="@android:drawable/checkbox_on_background"
                        app:tint="@android:color/white" />
                </LinearLayout>

                <!-- SUCCESS ANIMATION/ICON -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginTop="30dp"
                    android:background="@drawable/circle_bg_light_blue"
                    android:backgroundTint="#E8F5E9">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/checkbox_on_background"
                        app:tint="#4CAF50" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Report Submitted!"
                    android:textColor="#333333"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Your report has been received. A barangay official will review and respond shortly."
                    android:textColor="#666666"
                    android:textSize="15sp" />

                <!-- REPORT ID CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    app:cardBackgroundColor="#EDF2FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#D1D9FF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="20dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REPORT ID"
                            android:textColor="#4169E1"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvReportId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="RPT-2025-004"
                            android:textColor="#1A237E"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:text="You can track the status of this report under My Reports. You will be notified of any updates."
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <!-- SPACER to push button down if screen is tall -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- HOME BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackToHome"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="30dp"
                    android:layout_marginBottom="20dp"
                    android:text="Back to Home"
                    android:textSize="18sp"
                    android:textAllCaps="false"
                    app:backgroundTint="#4169E1"
                    app:cornerRadius="16dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
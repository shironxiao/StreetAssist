<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".ui.resident.Profile.ProfileFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER SECTION -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#4169E1"
                android:paddingTop="48dp"
                android:paddingBottom="60dp">

                <!-- Edit Profile Button at top-right -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditProfileHeader"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="16dp"
                    android:text="Edit Profile"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconTint="@android:color/white"
                    app:iconSize="16dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="120dp"
                        android:layout_height="120dp">

                        <!-- Profile photo (Cloudinary) -->
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/ivProfilePhoto"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_gravity="center"
                            android:src="@drawable/circle_bg_light_blue"
                            app:civ_border_color="#FFFFFF"
                            app:civ_border_width="3dp" />

                        <!-- Initials fallback (shown when no photo) -->
                        <TextView
                            android:id="@+id/tvInitials"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_gravity="center"
                            android:background="@drawable/circle_bg_light_blue"
                            android:gravity="center"
                            android:text="RS"
                            android:textColor="@android:color/white"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:visibility="visible" />

                        <com.google.android.material.floatingactionbutton.FloatingActionButton
                            android:id="@+id/fabEditPhoto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|end"
                            android:layout_margin="4dp"
                            app:backgroundTint="#FFFFFF"
                            app:fabCustomSize="32dp"
                            app:srcCompat="@android:drawable/ic_menu_edit"
                            app:tint="#4169E1" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Ronald Sevilla"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProfileSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RESIDENT · QUEZON CITY"
                        android:textColor="#D1D9FF"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />
                </LinearLayout>
            </RelativeLayout>

            <!-- CONTENT SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-35dp"
                android:background="@drawable/rounded_top_corners"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="PERSONAL SETTINGS"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- ── Row: Full Name ── -->
                        <LinearLayout
                            android:id="@+id/rowFullName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/circle_bg_light_blue"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="#4169E1" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Full Name"
                                    android:textColor="#333333"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvValFullName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ronald Sevilla"
                                    android:textColor="#757575" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F0F0F0"
                            android:layout_marginHorizontal="16dp" />

                        <!-- ── Row: Email (view-only) ── -->
                        <LinearLayout
                            android:id="@+id/rowEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/circle_bg_light_blue"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_dialog_email"
                                app:tint="#4169E1" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Email Address"
                                    android:textColor="#333333"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvValEmail"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ronald@email.com"
                                    android:textColor="#757575" />
                            </LinearLayout>

                            <!-- Lock icon to signal view-only -->
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@android:drawable/ic_lock_idle_lock"
                                app:tint="#CCCCCC" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F0F0F0"
                            android:layout_marginHorizontal="16dp" />

                        <!-- ── Row: Contact Number ── -->
                        <LinearLayout
                            android:id="@+id/rowContact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/circle_bg_light_blue"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_menu_call"
                                app:tint="#4169E1" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Contact Number"
                                    android:textColor="#333333"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvValContact"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textColor="#757575" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F0F0F0"
                            android:layout_marginHorizontal="16dp" />

                        <!-- ── Row: Address (view-only) ── -->
                        <LinearLayout
                            android:id="@+id/rowAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/circle_bg_light_blue"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_menu_mapmode"
                                app:tint="#4169E1" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Address"
                                    android:textColor="#333333"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvValAddress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Brgy. Commonwealth, QC"
                                    android:textColor="#757575" />
                            </LinearLayout>

                            <!-- Lock icon to signal view-only -->
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@android:drawable/ic_lock_idle_lock"
                                app:tint="#CCCCCC" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F0F0F0"
                            android:layout_marginHorizontal="16dp" />

                        <!-- ── Row: Change Password ── -->
                        <LinearLayout
                            android:id="@+id/rowPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/circle_bg_light_blue"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_lock_idle_lock"
                                app:tint="#4169E1" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Change Password"
                                    android:textColor="#333333"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tap edit to change your password"
                                    android:textColor="#BBBBBB"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Logout Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="24dp"
                    android:text="Log Out"
                    android:textColor="#FF4B2B"
                    android:textStyle="bold"
                    app:backgroundTint="#FFF5F5"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_lock_power_off"
                    app:iconGravity="textStart"
                    app:iconTint="#FF4B2B"
                    app:strokeColor="#FF4B2B"
                    app:strokeWidth="1dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
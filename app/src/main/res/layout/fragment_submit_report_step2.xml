<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".ui.resident.Reports.submit_report_step2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER SECTION -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#4169E1"
            android:padding="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_bg_light_blue"
                android:backgroundTint="#5A7FE6"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@android:color/white" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/btnBack"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Submit a Report"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Additional information"
                    android:textColor="#D1D9FF"
                    android:textSize="14sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- FORM SECTION -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="-20dp"
            android:background="@drawable/rounded_top_corners"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- STEP INDICATOR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp">

                    <!-- Step 1: Completed -->
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/circle_bg_light_blue"
                        android:backgroundTint="#4CAF50"
                        android:padding="6dp"
                        android:src="@android:drawable/checkbox_on_background"
                        app:tint="@android:color/white" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="#4CAF50"
                        android:layout_marginHorizontal="8dp" />

                    <!-- Step 2: Active -->
                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/circle_bg_light_blue"
                        android:backgroundTint="#4169E1"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="#D1D9FF"
                        android:layout_marginHorizontal="8dp" />

                    <!-- Step 3: Pending -->
                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/circle_bg_light_blue"
                        android:backgroundTint="#E0E0E0"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="#757575" />
                </LinearLayout>

                <!-- DESCRIPTION OF ASSISTANCE NEEDED (Renamed from Additional Notes) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="DESCRIPTION OF ASSISTANCE NEEDED"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:letterSpacing="0.1" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxStrokeColor="#4169E1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAssistanceDescription"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:gravity="top"
                        android:hint="Please describe what kind of assistance is needed (e.g., medical help, food, shelter, etc.)..." />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- CONTACT INFO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="YOUR CONTACT (OPTIONAL)"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:textSize="12sp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxStrokeColor="#4169E1"
                    app:startIconDrawable="@android:drawable/ic_menu_call">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etContactNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. 0917-000-0000"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Only shared with assigned barangay official."
                    android:textColor="#888888"
                    android:textSize="11sp" />

                <!-- NEXT BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNextStep2"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="20dp"
                    android:text="Next →"
                    android:textSize="18sp"
                    app:backgroundTint="#4169E1"
                    app:cornerRadius="16dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
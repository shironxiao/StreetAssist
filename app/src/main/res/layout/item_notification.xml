<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Unread blue dot -->
        <View
            android:id="@+id/dotUnread"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/circle_bg_light_blue"
            android:backgroundTint="#4169E1"
            android:visibility="gone" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvNotifTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/dotUnread"
            android:text="Notification Title"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Message -->
        <TextView
            android:id="@+id/tvNotifMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvNotifTitle"
            android:layout_marginTop="4dp"
            android:layout_toStartOf="@id/dotUnread"
            android:text="Notification message goes here."
            android:textColor="#555555"
            android:textSize="13sp" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvNotifTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvNotifMessage"
            android:layout_marginTop="6dp"
            android:text="Jan 01, 2025  08:00 AM"
            android:textColor="#AAAAAA"
            android:textSize="11sp" />

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>